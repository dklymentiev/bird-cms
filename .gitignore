# ==============================================================================
# Secrets — NEVER commit
# ==============================================================================
.env
.env.local
.env.*.local

# Operator/agent local config (machine-specific, may contain credentials)
.claude/

# ==============================================================================
# Per-deployment runtime data
# ==============================================================================
.engine-backup-*
storage/*
!storage/.gitkeep
!storage/README.md

# Runtime config — generated by the install wizard (Phase 1+) or install-site.sh.
# The repo ships templates that bootstrap.php compiles on first run.
config/app.php
config/categories.php

# Compiled nginx vhost (rendered from nginx.conf.template at build time)
templates/docker/unified/nginx.conf

# Symlinks created by entrypoint.sh on each container start. Tracking them
# would re-introduce the broken-symlink-on-host-clone bug: the targets
# (/var/www/html/...) only exist inside the container, so a host IDE sees
# them as dangling and refuses any write underneath.
public/uploads
public/content

# Demo runtime artifacts (created when the Docker container runs against the repo)
content/articles/*
!content/articles/.gitkeep
content/pages/*
!content/pages/.gitkeep
uploads/*
!uploads/.gitkeep
public/assets/hero/*
!public/assets/hero/.gitkeep
public/assets/images/*
public/assets/infographics/*
public/assets/editorial/*
public/assets/inline/*
public/assets/avatars/*
!public/assets/**/.gitkeep
!public/assets/**/README.md

# Tenant-specific themes -- engine ships only admin/install/tailwind.
themes/cleaning/

# Site-specific reports — never belong in the engine repo
audit/reports/

# Pre-hotfix backups created during in-place patching
*.pre-*

# ==============================================================================
# Release artifacts (built locally, distributed via GitLab Releases)
# ==============================================================================
releases/

# scripts/backup.sh default output dir
backups/

# ==============================================================================
# Dependencies
# ==============================================================================
vendor/
node_modules/

# ==============================================================================
# Editor / OS junk
# ==============================================================================
.idea/
.vscode/
*.swp
*~
.DS_Store
Thumbs.db

# ==============================================================================
# Tooling caches
# ==============================================================================
.coverage
.mypy_cache/
.phpunit.result.cache
.phpunit.cache/
tests/fixtures/tmp/

# Private dev content — kept in DOCI, not in git
worklog/
.ops/
audit/reports/
docs/MIGRATION-PLAN-*.md
docs/PERMISSIONS-FIX.md
docs/RELEASE-SYSTEM.md
docs/_*.md
MEMORY.md
CLAUDE.md.template
DAILY-ROUTINE.md.template
SEO-TOOLS.md.moved

# scratch files from local testing
_tmp_body.html
sample-parity-result.json

# Local docker-compose overrides (preview, port mapping, container names)
docker-compose.override.yml

# Design prototype for bird-cms.com -- live site has its own repo / admin.
landing/
