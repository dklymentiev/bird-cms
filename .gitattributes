# Enforce consistent line endings across platforms.
# Without this, Windows checkouts produce CRLF, Linux/macOS produce LF, and
# every cross-platform edit shows the whole file as "changed". This file fixes
# that by storing all text as LF and only converting on checkout if the OS
# explicitly opts in (it doesn't, by default).

* text=auto eol=lf

# Shell scripts and configs — must be LF (CRLF breaks shebangs and parsers)
*.sh        text eol=lf
*.bash      text eol=lf
Dockerfile  text eol=lf
*.conf      text eol=lf
*.ini       text eol=lf
*.template  text eol=lf

# Source code — LF
*.php  text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.xml  text eol=lf
*.svg  text eol=lf
*.py   text eol=lf
*.sql  text eol=lf

# Binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.tar   binary
*.gz    binary
*.tgz   binary
*.zip   binary
*.pdf   binary
