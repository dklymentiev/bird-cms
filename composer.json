{
    "name": "klymentiev/bird-cms",
    "description": "AI-first markdown CMS with native MCP support — your AI agent edits the site directly via stdio Model Context Protocol. Files on disk, git-friendly, no database.",
    "type": "project",
    "license": "MIT",
    "keywords": ["cms", "php", "markdown", "mcp", "model-context-protocol", "ai", "claude", "seo", "schema-org", "content-management", "static-content"],
    "authors": [
        {
            "name": "Dmytro Klymentiev",
            "homepage": "https://klymentiev.com"
        }
    ],
    "support": {
        "issues": "https://gitlab.com/codimcc/bird-cms/-/issues",
        "source": "https://gitlab.com/codimcc/bird-cms",
        "security": "https://gitlab.com/codimcc/bird-cms/-/blob/main/SECURITY.md"
    },
    "require": {
        "php": ">=8.1",
        "ext-mbstring": "*",
        "ext-json": "*",
        "ext-openssl": "*",
        "ext-curl": "*",
        "ext-gd": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/helpers/schema.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist"
    },
    "scripts": {
        "lint": "find app public scripts -name '*.php' -print0 | xargs -0 -n1 php -l | grep -v 'No syntax errors' || true",
        "test": "vendor/bin/phpunit",
        "smoke": "bash tests/smoke-test.sh",
        "release": "bash scripts/build-release.sh"
    }
}
